# Copy this file to .env in the repository root before running docker compose.

# CMS
PAYLOAD_SECRET=replace-with-a-strong-secret
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:4000

# Web (NEXT_PUBLIC values are injected at image build time)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WHATSAPP_NUMBER=256762267569

# Email notifications
RESEND_API_KEY=
ORDER_NOTIFICATION_FROM_EMAIL=info@russnails.com
ORDER_NOTIFICATION_TO_EMAIL=info@russnails.com
ENABLE_WHATSAPP_INQUIRY_EMAIL=true