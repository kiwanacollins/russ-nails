{
  "name": "russ-nails-cms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "payload generate:types && payload generate:importmap && next dev -p ${PORT:-4000} -H ${HOST:-0.0.0.0}",
    "start": "next start -p ${PORT:-4000} -H ${HOST:-0.0.0.0}",
    "build": "payload generate:types && payload generate:importmap && next build",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.80.0",
    "next": "^16.2.1",
    "payload": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.32",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.3"
  }
}
